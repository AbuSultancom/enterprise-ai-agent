{
  "version": 4,
  "llm": {
    "default_model": "openai:deepseek-chat"
  },
  "agent": {
    "name": "Enterprise AI Agent",
    "language": "auto",
    "personality": "a professional, concise enterprise assistant"
  },
  "security": {
    "note": "admin = full access, user = chat + read only"
  },
  "channels": {
    "whatsapp": {
      "role": "user"
    },
    "telegram": {
      "enabled": false
    }
  },
  "accounting": {
    "enabled": false,
    "read_only": true
  },
  "permissions": {
    "web_search": true,
    "calculator": true,
    "get_current_time": true,
    "read_file": true,
    "search_conversations": false,
    "generate_report": true,
    "list_reports": true,
    "accounting_tools": false,
    "knowledge_rag": true
  }
}