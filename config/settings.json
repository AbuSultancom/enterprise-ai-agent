{
  "version": 4,
  "llm": {
    "default_model": "ollama:qwen2.5:7b"
  },
  "agent": {
    "name": "Enterprise AI Agent",
    "language": "auto",
    "personality": "a professional, concise enterprise assistant"
  },
  "security": {
    "note": "admin = full access, user = chat + read only"
  },
  "channels": {
    "whatsapp": {
      "role": "user"
    },
    "telegram": {
      "enabled": false
    }
  },
  "accounting": {
    "enabled": true,
    "read_only": true,
    "allowed_queries": [
      "sales_summary",
      "revenue_by_month",
      "top_customers",
      "expenses_summary",
      "invoice_lookup",
      "cash_balance",
      "vendor_balances",
      "sales_by_item"
    ]
  },
  "permissions": {
    "web_search": true,
    "calculator": true,
    "get_current_time": true,
    "read_file": false,
    "search_conversations": true,
    "generate_report": true,
    "list_reports": true,
    "accounting_tools": true,
    "knowledge_rag": true
  }
}