# Copy to .env and fill in your own values
ADMIN_KEY=change-me-admin-key
USER_KEY=change-me-user-key
# OPENAI_API_KEY=sk-...
# HF_TOKEN=hf_...  # Hugging Face API token for better rate limits
# HF_BASE_URL=https://api-inference.huggingface.co
# VISION_MODEL=gpt-4o  # Vision-capable model for image analysis (e.g., gpt-4o, gpt-4o-mini, claude-3-opus)

# ─── Accounting / ERP Databases (MULTIPLE supported) ──────────
# Legacy env var — used as fallback when accounting_schema.json is not present.
# For multiple databases, use the setup wizard (python setup.py) or manage
# via config/accounting_schema.json directly.
# ACCOUNTING_DB_URL=mssql+pyodbc://readonly_user:password@192.168.1.10/OnyxDB?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# The config/accounting_schema.json file supports multiple databases:
#   - "onyx" (Onyx Pro accounting)
#   - "inventory" (Inventory DB)
#   - "hr" (HR database)
# Each entry has its own db_url, table mappings, and enabled flag.
# Use the API endpoints to manage them:
#   GET  /v1/accounting/databases     — list all configured DBs
#   POST /v1/accounting/databases     — add a new DB
#   DELETE /v1/accounting/databases/{key} — remove a DB
